# Database
DATABASE_URL=mysql://username:password@host:port/database

# Kimi OAuth (Required for authentication)
APP_ID=your_app_id
APP_SECRET=your_app_secret
KIMI_AUTH_URL=https://your_auth_url
KIMI_OPEN_URL=https://your_open_url

# Admin user (optional - sets this user as admin)
OWNER_UNION_ID=your_union_id

# Vercel — must be added in Vercel dashboard > Settings > Environment Variables
# (NOT just in .env — Vercel must inject it at runtime to disable its Node.js helpers,
#  which conflict with Hono's Web Standard fetch handler)
NODEJS_HELPERS=0
